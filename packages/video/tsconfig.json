{
	"extends": "@vibestack/config/tsconfig.base.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"types": ["node"],
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"strict": true,
		"noEmit": true
	},
	"include": ["src/**/*", "scripts/**/*"]
}
