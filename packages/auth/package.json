{
	"name": "@vibestack/auth",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./permissions": {
			"default": "./src/lib/permissions.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"generate": "npx -y @better-auth/cli@latest generate --output ../db/src/schema/auth.ts --config ./src/index.ts -y"
	},
	"dependencies": {
		"@better-auth/passkey": "catalog:",
		"@polar-sh/better-auth": "catalog:",
		"@polar-sh/sdk": "catalog:",
		"@vibestack/billing": "workspace:*",
		"@vibestack/db": "workspace:*",
		"@vibestack/email": "workspace:*",
		"@vibestack/env": "workspace:*",
		"better-auth": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "catalog:",
		"ioredis": "catalog:",
		"nanoid": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@better-auth/cli": "^1.4.21",
		"@vibestack/config": "workspace:*",
		"typescript": "catalog:"
	}
}
