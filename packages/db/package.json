{
	"name": "@vibestack/db",
	"type": "module",
	"exports": {
		".": {
			"default": "./src/index.ts"
		},
		"./*": {
			"default": "./src/*.ts"
		}
	},
	"scripts": {
		"db:push": "drizzle-kit push",
		"db:seed": "tsx scripts/seed.ts",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio",
		"db:migrate": "drizzle-kit migrate",
		"db:start": "docker compose -f ../../docker-compose.yml up -d",
		"db:watch": "docker compose -f ../../docker-compose.yml up",
		"db:stop": "docker compose -f ../../docker-compose.yml stop",
		"db:down": "docker compose -f ../../docker-compose.yml down"
	},
	"dependencies": {
		"@vibestack/env": "workspace:*",
		"dotenv": "catalog:",
		"drizzle-orm": "catalog:",
		"pg": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@vibestack/config": "workspace:*",
		"@types/pg": "catalog:",
		"drizzle-kit": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:"
	}
}
