# ============================================================================
# Copy to .env (dev) or .env.production (Dokploy) and fill in.
# Anything starting with NEXT_PUBLIC_ is exposed to the browser.
# ============================================================================

NODE_ENV=development

# Core URLs
APP_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Database (self-hosted Postgres via docker-compose)
DATABASE_URL=postgresql://postgres:password@localhost:5432/starter-saas
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=starter-saas

# Better Auth
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-32-char-secret-replace-with-32-char-
BETTER_AUTH_URL=http://localhost:3001

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Polar.sh (billing)
# Get at https://sandbox.polar.sh
POLAR_ACCESS_TOKEN=
POLAR_SUCCESS_URL=http://localhost:3001/success?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=

# Resend (email)
RESEND_API_KEY=
EMAIL_FROM=hello@example.com

# Cloudflare R2 (storage + nightly DB backup)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=starter-saas
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_URL=
R2_BACKUP_PREFIX=backups

# PostHog (analytics)
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Google Analytics 4
NEXT_PUBLIC_GA_ID=

# Sentry (errors)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Redis (rate-limit / Better Auth secondary storage / queues)
# Runs via docker-compose (see docker-compose.yml service "redis")
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
